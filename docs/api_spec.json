    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/anos": {
      "get": {
        "summary": "Listar todos los años registrados en el sistema",
        "tags": [
          "registrar socios e invitados asociados a un año (año deportivo o calendario) y registrar pagos mensuales (cuotas y cobros por mes)"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "summary": "Crear un nuevo año deportivo",
        "tags": [
          "registrar socios e invitados asociados a un año (año deportivo o calendario) y registrar pagos mensuales (cuotas y cobros por mes)"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "Conflict"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
