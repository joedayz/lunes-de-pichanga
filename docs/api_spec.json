            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Filtrar por año (default: año actual)"
          },
          {
            "name": "pagina",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Número de página (default: 1)"
