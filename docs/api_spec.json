{
  "openapi": "3.0.0",
  "info": {
    "title": "API: corregir el build del frontend en Vite",
    "version": "1.0.0"
  },
  "paths": {
    "/api/socios": {
      "get": {
        "summary": "Obtener lista de todos los socios registrados",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [
          {
            "name": "estado",
            "in": "path",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtrar por estado (activo, inactivo)"
          },
          {
            "name": "page",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Número de página para paginación"
          },
          {
            "name": "limit",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Cantidad de registros por página"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "summary": "Registrar un nuevo socio y crear cuota inicial",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "Conflict"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/socios/:id/cuotas": {
      "get": {
        "summary": "Obtener historial de cuotas de un socio específico",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del socio"
          },
          {
            "name": "estado",
            "in": "path",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtrar por estado (pendiente, pagada, vencida)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/cuotas/:id/pagar": {
      "patch": {
        "summary": "Registrar pago de una cuota",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID de la cuota"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/dashboard/resumen": {
      "get": {
        "summary": "Obtener resumen del dashboard administrativo (socios activos, cuotas pendientes, próximas pichangas)",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/socios/:id": {
      "get": {
        "summary": "Obtener detalles completos de un socio (perfil, cuotas, asistencias)",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del socio"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}
