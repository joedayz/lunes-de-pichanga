{
  "openapi": "3.0.0",
  "info": {
    "title": "API: corregir el build del frontend en Vite",
    "version": "1.0.0"
  },
  "paths": {
    "/api/socios": {
      "get": {
        "summary": "Obtener lista de todos los socios registrados",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "summary": "Registrar un nuevo socio en el sistema",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "Conflict"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/cuotas": {
      "post": {
        "summary": "Registrar una nueva cuota para un socio",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/socios/:socio-id/cuotas": {
      "get": {
        "summary": "Obtener todas las cuotas de un socio específico",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [
          {
            "name": "socio-id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del socio"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/cuotas/:cuota-id/pagar": {
      "patch": {
        "summary": "Registrar el pago de una cuota",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [
          {
            "name": "cuota-id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID de la cuota"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/dashboard/resumen": {
      "get": {
        "summary": "Obtener resumen del dashboard administrativo (socios activos, cuotas pendientes, próximas pichangas)",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}
