{
  "openapi": "3.0.0",
  "info": {
    "title": "API: quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000",
    "version": "1.0.0"
  },
  "paths": {
    "/api/anos-disponibles": {
      "get": {
        "summary": "Obtiene lista de años con datos disponibles en el sistema (p.ej. años con socios o cuotas registradas)",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/socios": {
      "get": {
        "summary": "Obtiene lista de socios, opcionalmente filtrada por año. Responde siempre como array JSON raíz para permitir .map() directo en frontend",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [
          {
            "name": "anio",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Año para filtrar socios (query param). Si no se proporciona, devuelve todos"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "summary": "Crea un nuevo socio",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/invitados": {
      "get": {
        "summary": "Obtiene lista de invitados filtrada por año. Responde como array JSON raíz",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [
          {
            "name": "anio",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año para filtrar invitados"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/dashboard/resumen": {
      "get": {
        "summary": "Obtiene resumen del dashboard para un año específico: total de socios, invitados y recaudado",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [
          {
            "name": "anio",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año para calcular el resumen"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/dashboard/cuotas": {
      "get": {
        "summary": "Obtiene lista de cuotas/pagos para un año específico. Responde como array JSON raíz",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [
          {
            "name": "anio",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año para filtrar cuotas"
          },
          {
            "name": "mes",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Mes opcional para filtrar cuotas (1-12)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/pagos": {
      "post": {
        "summary": "Registra un nuevo pago/cuota. Alias que delega a la lógica de cuotas existente. Acepta el mismo schema que POST /api/cuotas",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/cuotas": {
      "post": {
        "summary": "Registra una nueva cuota (pago). Endpoint principal; POST /api/pagos delega aquí",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/socios/:id": {
      "get": {
        "summary": "Obtiene detalles de un socio específico por ID",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del socio"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/dashboard/cuotas/:socioId": {
      "get": {
        "summary": "Obtiene historial de cuotas/pagos de un socio específico",
        "tags": [
          "quitar el formulario legacy inferior y evitar errores 404/formato incorrecto contra http://localhost:4000"
        ],
        "parameters": [
          {
            "name": "socioId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del socio"
          },
          {
            "name": "anio",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Filtrar por año (query param)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}
