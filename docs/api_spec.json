{
  "openapi": "3.0.0",
  "info": {
    "title": "API: una interfaz única minimalista",
    "version": "1.0.0"
  },
  "paths": {
    "/api/socios": {
      "get": {
        "summary": "Listar socios filtrados por año. Retorna array raíz de socios.",
        "tags": [
          "una interfaz única minimalista"
        ],
        "parameters": [
          {
            "name": "año",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año de afiliación para filtrar"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "summary": "Crear nuevo socio. Si no se proporciona año_afiliacion, usa el año actual.",
        "tags": [
          "una interfaz única minimalista"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/invitados": {
      "get": {
        "summary": "Listar invitados filtrados por año. Retorna array raíz de invitados.",
        "tags": [
          "una interfaz única minimalista"
        ],
        "parameters": [
          {
            "name": "año",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año para filtrar invitados"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "summary": "Crear nuevo invitado. Si no se proporciona año, usa el año actual.",
        "tags": [
          "una interfaz única minimalista"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/pagos": {
      "get": {
        "summary": "Listar pagos filtrados por año y opcionalmente por mes. Retorna array raíz de pagos.",
        "tags": [
          "una interfaz única minimalista"
        ],
        "parameters": [
          {
            "name": "año",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año para filtrar pagos"
          },
          {
            "name": "mes",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Mes (1-12) para filtrar pagos adicionales"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "summary": "Registrar nuevo pago para un socio.",
        "tags": [
          "una interfaz única minimalista"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/dashboard": {
      "get": {
        "summary": "Obtener resumen compacto del año: total socios, total invitados, recaudación total.",
        "tags": [
          "una interfaz única minimalista"
        ],
        "parameters": [
          {
            "name": "año",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año para el resumen del dashboard"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}
