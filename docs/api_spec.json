{
  "openapi": "3.0.0",
  "info": {
    "title": "API: corregir el build del frontend en Vite",
    "version": "1.0.0"
  },
  "paths": {
    "/api/build-status": {
      "get": {
        "summary": "Verifica el estado del build de Vite y retorna información sobre errores en la compilación del frontend",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/components/una-aplicacin-web/validate": {
      "get": {
        "summary": "Valida la estructura del archivo index.tsx: imports únicos, BASE_URL declarado una sola vez, único export default",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/components/una-aplicacin-web/fix": {
      "post": {
        "summary": "Aplica correcciones automáticas al archivo index.tsx: reorganiza imports, consolida BASE_URL, asegura único export default",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "422": {
            "description": "Response"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/components/una-aplicacin-web/structure": {
      "get": {
        "summary": "Retorna la estructura actual del archivo index.tsx: imports, constantes, exports, componentes detectados",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/components/extract": {
      "post": {
        "summary": "Extrae un componente del archivo index.tsx a un archivo separado manteniendo imports y dependencias",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "422": {
            "description": "Response"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/dev-server/health": {
      "get": {
        "summary": "Verifica si el servidor de desarrollo (Vite) está corriendo correctamente en http://localhost:5173",
        "tags": [
          "corregir el build del frontend en Vite"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          },
          "503": {
            "description": "Response"
          }
        }
      }
    }
  }
}
