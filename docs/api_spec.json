{
  "openapi": "3.0.0",
  "info": {
    "title": "API: una aplicación web",
    "version": "1.0.0"
  },
  "paths": {
    "/api/socios": {
      "post": {
        "summary": "Registrar un nuevo socio del grupo deportivo",
        "tags": [
          "una aplicación web"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "Conflict"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/cuotas": {
      "post": {
        "summary": "Registrar pago de cuota mensual de socio (15 soles) o participación de invitado (5 soles)",
        "tags": [
          "una aplicación web"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/transacciones": {
      "post": {
        "summary": "Registrar gasto (pelotas, chalecos) o ingreso extra (rifas, campeonatos)",
        "tags": [
          "una aplicación web"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/reportes/resumen": {
      "get": {
        "summary": "Obtener resumen de ingresos y gastos por mes y año, con fondo anual por socio y saldo para canasta",
        "tags": [
          "una aplicación web"
        ],
        "parameters": [
          {
            "name": "mes",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Mes específico (1-12)"
          },
          {
            "name": "anio",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año del reporte"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/socios/:socio-id/fondo": {
      "get": {
        "summary": "Obtener fondo anual acumulado de un socio específico",
        "tags": [
          "una aplicación web"
        ],
        "parameters": [
          {
            "name": "socio-id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID del socio"
          },
          {
            "name": "anio",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año para calcular el fondo"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/reportes/detalles": {
      "get": {
        "summary": "Obtener detalles de todas las transacciones (cuotas, gastos, ingresos) filtradas por período",
        "tags": [
          "una aplicación web"
        ],
        "parameters": [
          {
            "name": "mes",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Mes específico (1-12)"
          },
          {
            "name": "anio",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Año del reporte"
          },
          {
            "name": "tipo",
            "in": "path",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filtrar por tipo: 'cuota', 'gasto', 'ingreso'"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}
