          {
            "name": "limite",
            "in": "path",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Registros por página (default: 20)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
